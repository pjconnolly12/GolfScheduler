@page
@model IndexModel
@{
    ViewData["Title"] = "Upcoming Golf Rounds";
}

<h1 class="mb-3">Upcoming Rounds</h1>

@if (!string.IsNullOrWhiteSpace(TempData["GuestUpdateErrorMessage"] as string))
{
    <div class="alert alert-danger" role="alert">
        @TempData["GuestUpdateErrorMessage"]
    </div>
}

@if (!Model.UpcomingRounds.Any())
{
    <p>No upcoming rounds yet. <a asp-page="/Rounds/Create">Add one</a>.</p>
}
else
{
    @foreach (var round in Model.UpcomingRounds)
    {
        // Separate active entries and waitlist entries
        var activeEntries = round.Entries?
        .Where(e =>
        !e.Status.Equals("Waitlist", StringComparison.OrdinalIgnoreCase) &&
        (e.Status != "Maybe" || (e.ExpiresAt ?? DateTime.MaxValue) > DateTime.UtcNow))
        .ToList() ?? new List<MyApp.Models.Entry>();

        var waitlistEntries = round.Entries?
        .Where(e => e.Status.Equals("Waitlist", StringComparison.OrdinalIgnoreCase))
        .ToList() ?? new List<MyApp.Models.Entry>();

        int totalPlayers = activeEntries.Sum(e => 1 + (e.Guests ?? 0));

        <div class="card mb-4 shadow-sm round-card">
            <div class="card-header bg-success text-white d-flex flex-column flex-md-row justify-content-between gap-1">
                <div class="fw-semibold">
                    <strong>@round.Course</strong> — @round.Date.ToString("dddd, MMM d, yyyy h:mm tt")
                </div>
                <div class="small text-md-end">
                    @totalPlayers / @round.PlayerLimit player(s) signed up
                </div>
            </div>

            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(round.Notes))
                {
                    <p class="text-muted mb-3">@round.Notes</p>
                }

                @if (activeEntries.Any())
                {
                    <div class="table-responsive mobile-table-wrap mb-3">
                        <table class="table table-sm table-striped mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Player</th>
                                    <th>Guests</th>
                                    <th>Status</th>
                                    <th>Expires At</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in activeEntries)
                                {
                                    <tr>
                                        <td>@entry.Player?.Name</td>
                                        <td>
                                            @if (entry.PlayerId.ToString() == Model.CurrentPlayerId)
                                            {
                                                <!-- Update button (only visible to owner) -->
                                                <form method="post" asp-page="/Entries/Create" asp-page-handler="UpdateGuests" class="guest-update-form d-flex flex-wrap gap-2 align-items-center">
                                                    <input type="hidden" name="entryId" value="@entry.Id" />
                                                    <input type="number" name="newGuests" value="@(entry.Guests ?? 0)" min="0" max="@(Math.Max(round.PlayerLimit - 1, 0))"
                                                        class="form-control form-control-sm" />
                                                    <button type="submit" class="btn btn-sm btn-primary">Update</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span>@(entry.Guests ?? 0)</span>
                                            }
                                        </td>
                                        <td>@entry.Status</td>
                                        <td>
                                            @if (entry.Status.Equals("Maybe", StringComparison.OrdinalIgnoreCase) &&
                                                                                        entry.ExpiresAt.HasValue)
                                            {
                                                @entry.ExpiresAt.Value.ToLocalTime().ToString("g")
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                        <td>
                                            @if (entry.PlayerId.ToString() == Model.CurrentPlayerId)
                                            {
                                                @if (entry.Status.Equals("Maybe", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <form method="post" asp-page="/Entries/Create" asp-page-handler="UpdateStatus" class="d-inline-block me-2">
                                                        <input type="hidden" name="entryId" value="@entry.Id" />
                                                        <input type="hidden" name="newStatus" value="Confirmed" />
                                                        <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                                                    </form>
                                                }

                                                <!-- Remove button (only visible to owner) -->
                                                <form method="post" asp-page="/Entries/Create" asp-page-handler="Remove" class="d-inline-block">
                                                    <input type="hidden" name="entryId" value="@entry.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p>No active players have joined yet.</p>
                }

                @* --- WAITLIST SECTION --- *@
                @if (waitlistEntries.Any())
                {
                    <div class="mt-4 p-3 border-top">
                        <h6 class="text-muted mb-2">Waitlist</h6>
                        <div class="table-responsive mobile-table-wrap">
                        <table class="table table-sm mb-0 align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Player</th>
                                    <th>Guests</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var entry in waitlistEntries)
                                {
                                    <tr>
                                        <td>@entry.Player?.Name</td>
                                        <td>@(entry.Guests ?? 0)</td>
                                        <td>
                                            @if (entry.PlayerId.ToString() == Model.CurrentPlayerId)
                                            {
                                                <form method="post" asp-page="/Entries/Create" asp-page-handler="Remove" class="d-inline-block">
                                                    <input type="hidden" name="entryId" value="@entry.Id" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        </div>
                    </div>
                }

                @if (totalPlayers < round.PlayerLimit)
                {
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-page="/Entries/Create" asp-route-roundId="@round.Id" asp-route-status="Confirmed"
                            class="btn btn-primary round-cta mt-2">
                            Join Round
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Account/Login" class="btn btn-primary round-cta mt-2">
                            Log in to Join
                        </a>
                    }
                }
                else
                {
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        <a asp-page="/Entries/Create" asp-route-roundId="@round.Id" asp-route-status="Waitlist"
                            class="btn btn-warning round-cta mt-2">
                            Join Waitlist
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Account/Login" class="btn btn-warning round-cta mt-2">
                            Log in to Join Waitlist
                        </a>
                    }
                }
            </div>
        </div>
    }
}
